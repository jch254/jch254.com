---
/**
 * Blog post card for listing pages.
 * Shows hero image (if available), title, excerpt, date, and tags.
 */

interface Props {
  title: string;
  description: string;
  date: Date;
  slug: string;
  tags?: string[];
}

const { title, description, date, slug, tags = [] } = Astro.props;

const formattedDate = date.toLocaleDateString('en-NZ', {
  year: 'numeric',
  month: 'short',
  day: 'numeric',
});
---

<article class="group">
  <a
    href={`/blog/${slug}`}
    class="block overflow-hidden rounded-2xl bg-brand-card border border-brand-border transition-all duration-300 hover:border-brand-accent/40 hover:bg-brand-card-hover hover:shadow-lg hover:shadow-brand-accent/5"
  >
    <div class="flex flex-col sm:flex-row">
      <!-- Text content -->
      <div class="flex flex-1 flex-col justify-between p-5">
        <div>
          <time class="mb-2 block text-xs font-medium uppercase tracking-wider text-brand-muted">
            {formattedDate}
          </time>
          <h3 class="mb-2 text-lg font-bold leading-snug text-white transition-colors group-hover:text-brand-accent">
            {title}
          </h3>
          <p class="line-clamp-2 text-sm leading-relaxed text-brand-muted">
            {description}
          </p>
        </div>

        <div class="mt-4 flex flex-col gap-3 sm:flex-row sm:items-center sm:justify-between">
          {tags.length > 0 && (
            <div class="flex flex-wrap gap-1.5">
              {tags.slice(0, 3).map((tag) => (
                <span class="rounded-full bg-brand-accent/10 px-2.5 py-0.5 text-xs font-medium text-brand-accent">
                  {tag}
                </span>
              ))}
            </div>
          )}
          <span class="inline-flex items-center gap-1 text-sm font-semibold text-brand-accent transition-transform group-hover:translate-x-0.5">
            Read more
            <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3" />
            </svg>
          </span>
        </div>
      </div>
    </div>
  </a>
</article>
