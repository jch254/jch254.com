---
/**
 * Section link card used on the home page bottom
 * (Blog, Portfolio, GitHub links).
 */

interface Props {
  title: string;
  description: string;
  href: string;
  ctaLabel: string;
  external?: boolean;
}

const { title, description, href, ctaLabel, external = false } = Astro.props;
---

<a
  href={href}
  target={external ? '_blank' : undefined}
  rel={external ? 'noopener noreferrer' : undefined}
  class="group flex h-full flex-col overflow-hidden rounded-2xl bg-brand-card border border-brand-border p-6 transition-all duration-300 hover:border-brand-accent/40 hover:bg-brand-card-hover hover:shadow-lg hover:shadow-brand-accent/5"
>
  <h3 class="mb-1 font-mono text-lg font-bold text-white">
    &lt;/{title.toUpperCase()}&gt;
  </h3>
  <p class="mb-4 flex-1 text-sm text-brand-muted">{description}</p>
  <span class="flex items-center justify-center gap-1.5 whitespace-nowrap rounded-full bg-brand-accent px-4 py-2 text-xs font-semibold uppercase tracking-wider text-white transition hover:bg-brand-accent-hover">
    {ctaLabel}
    <svg xmlns="http://www.w3.org/2000/svg" class="h-3.5 w-3.5 flex-shrink-0 transition-transform group-hover:translate-x-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
      <path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3" />
    </svg>
  </span>
</a>
