---
/**
 * Footer component with copyright and minimal branding.
 */
const year = new Date().getFullYear();
---

<footer class="border-t border-brand-border py-8">
  <div class="mx-auto max-w-2xl px-6 text-center text-sm text-brand-muted">
    <p>&copy; {year} Jordan Hornblow. Built with <a href="https://astro.build" target="_blank" rel="noopener noreferrer" class="text-brand-accent underline decoration-brand-accent/40 hover:decoration-brand-accent">Astro</a>. <a href="https://github.com/jch254/jch254.com" target="_blank" rel="noopener noreferrer" class="text-brand-accent underline decoration-brand-accent/40 hover:decoration-brand-accent">GitHub</a>. <a href="/rss.xml" target="_blank" rel="noopener noreferrer" class="text-brand-accent underline decoration-brand-accent/40 hover:decoration-brand-accent">RSS</a>.</p>
  </div>
</footer>
