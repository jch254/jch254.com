---
import BaseLayout from '../layouts/BaseLayout.astro';
import Hero from '../components/Hero.astro';
import Footer from '../components/Footer.astro';
---

<BaseLayout title="404 — Page Not Found">
  <Hero compact />

  <main class="mx-auto max-w-2xl px-6 py-24 text-center">
    <h1 class="mb-4 text-6xl font-extrabold tracking-tight text-brand-accent">404</h1>
    <p class="mb-8 text-lg text-brand-muted">This page doesn't exist. Maybe it never did.</p>
    <a
      href="/"
      class="inline-flex items-center gap-2 rounded-full bg-brand-accent px-6 py-2.5 text-sm font-semibold text-white transition hover:bg-brand-accent-hover"
    >
      <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
        <path stroke-linecap="round" stroke-linejoin="round" d="M7 16l-4-4m0 0l4-4m-4 4h18" />
      </svg>
      Back home
    </a>
  </main>

  <Footer />
</BaseLayout>
