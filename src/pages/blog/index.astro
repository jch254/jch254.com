---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import Hero from '../../components/Hero.astro';
import Breadcrumb from '../../components/Breadcrumb.astro';
import BlogCard from '../../components/BlogCard.astro';
import Footer from '../../components/Footer.astro';

const posts = (await getCollection('blog', ({ data }) => !data.draft && !data.unlisted))
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());
---

<BaseLayout title="Blog | Jordan Hornblow" description="Posts on whatever is on my mind.">
  <Hero compact />

  <Breadcrumb items={[
    { label: 'Jordan Hornblow', href: '/' },
    { label: 'Blog' },
  ]} />

  <main class="mx-auto max-w-2xl px-6 pb-16">
    <div class="mb-8 flex items-start justify-between gap-4">
      <div>
        <h2 class="mb-2 text-2xl font-extrabold tracking-tight md:text-3xl">Blog</h2>
        <p class="text-sm text-brand-muted">Writing about engineering, AI, systems, and the human side of building technology.</p>
      </div>
      <a href="/rss.xml" target="_blank" rel="noopener noreferrer" class="mt-1 flex shrink-0 items-center gap-1.5 rounded-md border border-brand-border px-3 py-1.5 text-xs font-medium text-brand-muted transition-colors hover:border-brand-accent hover:text-brand-accent" title="Subscribe via RSS">
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" class="h-3.5 w-3.5"><path d="M3.75 3a.75.75 0 0 0-.75.75v.5c0 9.525 7.725 17.25 17.25 17.25h.5a.75.75 0 0 0 0-1.5h-.5A15.75 15.75 0 0 1 4.5 4.25v-.5A.75.75 0 0 0 3.75 3Zm0 6a.75.75 0 0 0-.75.75v.5c0 6.213 5.037 11.25 11.25 11.25h.5a.75.75 0 0 0 0-1.5h-.5A9.75 9.75 0 0 1 4.5 10.25v-.5A.75.75 0 0 0 3.75 9ZM6 18.75a1.5 1.5 0 1 1-3 0 1.5 1.5 0 0 1 3 0Z"/></svg>
        RSS
      </a>
    </div>

    <div class="space-y-4">
      {posts.map((post) => (
        <BlogCard
          title={post.data.title}
          description={post.data.description}
          date={post.data.date}
          slug={post.id.replace(/\.(md|mdx)$/, '')}
          tags={post.data.tags}
        />
      ))}
    </div>

    {posts.length === 0 && (
      <p class="py-12 text-center text-brand-muted">No posts yet. Check back soon!</p>
    )}
  </main>

  <Footer />
</BaseLayout>
